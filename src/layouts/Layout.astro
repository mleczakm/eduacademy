---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;
const isHomepage = currentPath === '/';
const isAboutPage = currentPath === '/o-nas';
const isContactPage = currentPath === '/kontakt';
const isCoursesPage = currentPath.startsWith('/szkolenia');
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - Future Edu Academy</title>
    <meta
      name="description"
      content="Future Edu Academy - Warsztaty i szkolenia dla dzieci, nauczycieli i seniorów"
    />
    <meta property="og:image" content="https://eduacademy.pl/logo.png" />
    <meta property="twitter:image" content="https://eduacademy.pl/logo.png" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link rel="preload" href="/logo.webp" as="image" type="image/webp" />
    <script is:inline defer>
      // Redirect Netlify Identity email tokens to the CMS admin panel
      const hash = window.location.hash;
      if (
        hash &&
        (hash.includes('invite_token=') ||
          hash.includes('recovery_token=') ||
          hash.includes('confirmation_token='))
      ) {
        window.location.replace('/admin/' + hash);
      }
    </script>
  </head>
  <body class="text-slate-700 min-h-screen flex flex-col">
    <header
      class="bg-white/80 backdrop-blur-md shadow-sm sticky top-0 z-50 border-b border-slate-100"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-20 items-center">
          <!-- Logo -->
          <a href="/" class="flex-shrink-0 flex items-center gap-3">
            <picture>
              <source srcset="/logo.webp" type="image/webp" />
              <img
                src="/logo.png"
                alt="Future Edu Academy Logo"
                class="h-10 object-contain"
                width="40"
                height="40"
              />
            </picture>
            <span class="text-2xl md:text-3xl font-semibold text-brandPrimary tracking-tight">
              Future Edu <span class="text-brandAccent font-light">Academy</span>
            </span>
          </a>

          <!-- Desktop Menu -->
          <nav class="hidden md:flex space-x-8">
            <a
              href={isHomepage ? '#katalog' : '/'}
              class={isHomepage || isCoursesPage
                ? 'text-brandPrimary font-semibold transition border-b-2 border-brandPrimary pb-1'
                : 'text-slate-600 hover:text-brandPrimary font-medium transition pb-1'}
              >Katalog Warsztatów</a
            >
            <a
              href="/o-nas"
              class={isAboutPage
                ? 'text-brandPrimary font-semibold transition border-b-2 border-brandPrimary pb-1'
                : 'text-slate-600 hover:text-brandPrimary font-medium transition pb-1'}>O nas</a
            >
            <a
              href="/kontakt"
              class={isContactPage
                ? 'text-brandPrimary font-semibold transition border-b-2 border-brandPrimary pb-1'
                : 'text-slate-600 hover:text-brandPrimary font-medium transition pb-1'}>Kontakt</a
            >
          </nav>

          <!-- Mobile Menu Button -->
          <div class="flex items-center space-x-4">
            <button id="mobile-menu-btn" class="md:hidden text-slate-600 hover:text-brandPrimary">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-7 w-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
            </button>
          </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <nav class="flex flex-col space-y-3">
            <a
              href={isHomepage ? '#katalog' : '/'}
              class={isHomepage || isCoursesPage
                ? 'text-brandPrimary font-semibold transition'
                : 'text-slate-600 hover:text-brandPrimary font-medium transition'}
              >Katalog Warsztatów</a
            >
            <a
              href="/o-nas"
              class={isAboutPage
                ? 'text-brandPrimary font-semibold transition'
                : 'text-slate-600 hover:text-brandPrimary font-medium transition'}>O nas</a
            >
            <a
              href="/kontakt"
              class={isContactPage
                ? 'text-brandPrimary font-semibold transition'
                : 'text-slate-600 hover:text-brandPrimary font-medium transition'}>Kontakt</a
            >
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-grow">
      <slot />
    </main>

    <footer class="bg-slate-900 text-slate-400 py-12 border-t border-slate-800">
      <div
        class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center"
      >
        <div class="mb-6 md:mb-0 text-center md:text-left">
          <div class="flex items-center justify-center md:justify-start gap-2 mb-2">
            <picture>
              <source srcset="/logo.webp" type="image/webp" />
              <img
                src="/logo.png"
                alt="Future Edu Academy Logo"
                class="h-10 object-contain"
                width="119"
                height="119"
                loading="lazy"
              />
            </picture>
            <span class="text-2xl font-semibold text-white tracking-tight">
              Future Edu <span class="text-brandAccent font-light">Academy</span>
            </span>
          </div>
          <p class="text-xs">Miejsce inspirujących spotkań i twórczego rozwoju dla każdego.</p>
        </div>
        <div class="flex space-x-6">
          <a href="/regulamin" class="hover:text-white transition text-sm">Regulamin</a>
          <a href="/polityka-prywatnosci" class="hover:text-white transition text-sm"
            >Polityka prywatności</a
          >
          <a href="/kontakt" class="hover:text-white transition text-sm">Kontakt</a>
        </div>
      </div>
    </footer>

    <!-- Global Enrollment Modal -->
    <div
      id="enroll-modal"
      class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center hidden"
    >
      <div class="bg-white rounded-xl p-8 max-w-md w-full shadow-2xl">
        <h3 id="modal-title" class="text-2xl font-bold text-slate-800 mb-4">
          Formularz kontaktowy
        </h3>

        <!-- Integration with Formspree -->
        <form action="https://formspree.io/f/TWOJ_ID_FORMSPREE" method="POST" class="space-y-4">
          <!-- Ukryte pole z nazwą kursu (automatyczne przypisanie) -->
          <input type="hidden" id="modal-course-input" name="Szkolenie" value="" />

          <div>
            <label for="modal-name" class="block text-sm font-bold text-slate-600 mb-1"
              >Imię i nazwisko</label
            >
            <input
              id="modal-name"
              type="text"
              name="name"
              required
              class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
            />
          </div>
          <div>
            <label for="modal-email" class="block text-sm font-bold text-slate-600 mb-1"
              >Adres E-mail</label
            >
            <input
              id="modal-email"
              type="email"
              name="email"
              required
              class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
            />
          </div>
          <div>
            <label for="modal-message" class="block text-sm font-bold text-slate-600 mb-1"
              >Wiadomość / Pytania</label
            >
            <textarea
              id="modal-message"
              name="message"
              rows="3"
              class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
              placeholder=""></textarea>
          </div>

          <button
            type="submit"
            class="w-full bg-brandPrimary hover:bg-brandPrimaryDark text-white font-bold py-3.5 rounded-xl transition shadow-md"
          >
            Wyślij zgłoszenie
          </button>
        </form>
        <button
          onclick="document.getElementById('enroll-modal').classList.add('hidden')"
          class="mt-4 text-slate-400 hover:text-slate-600 text-sm font-bold w-full text-center"
        >
          Anuluj
        </button>
      </div>
    </div>

    <script>
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      if (mobileMenuBtn && mobileMenu) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }

      // Global function to open enrollment modal with course title
      function openEnrollModal(courseTitle: string) {
        const modal = document.getElementById('enroll-modal');
        const modalTitle = document.getElementById('modal-title');
        const courseInput = document.getElementById('modal-course-input') as HTMLInputElement;
        const messageArea = document.getElementById('modal-message') as HTMLTextAreaElement;

        if (modal && modalTitle && courseInput && messageArea) {
          modalTitle.textContent = 'Zapisz się na zajęcia';
          courseInput.value = courseTitle;
          messageArea.placeholder = `Jestem zainteresowana/-y kursem "${courseTitle}", proszę o kontakt w sprawie rejestracji na zajęcia.`;
          messageArea.value = messageArea.placeholder;
          modal.classList.remove('hidden');
        }
      }

      // Expose function to global scope
      declare global {
        interface Window {
          openEnrollModal: (courseTitle: string) => void;
        }
      }
      window.openEnrollModal = openEnrollModal;
    </script>
  </body>
</html>
