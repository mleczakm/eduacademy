---
import Layout from '../layouts/Layout.astro';
import HeroAI from '../components/HeroAI.astro';
import CourseCard from '../components/CourseCard.astro';
import { getCollection } from 'astro:content';

const allCourses = await getCollection('courses');

// Extract all unique tags from courses
const courseTags = new Set<string>();
for (const course of allCourses) {
  if (course.data.tags) {
    course.data.tags.forEach((tag) => courseTags.add(tag));
  }
}

// Handle anchor link redirection
if (Astro.url.hash) {
  const targetId = Astro.url.hash.replace('#', '');
  Astro.redirect(`/#${targetId}`);
}
---

<Layout title="Future Edu Academy">
  <HeroAI />

  <!-- Główna Sekcja Katalogu -->
  <section id="katalog" class="py-12 md:py-20 bg-white flex-grow">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span
          class="text-brandPrimary font-bold text-sm tracking-wider uppercase bg-brandAccentLight px-3 py-1 rounded-full"
          >Nasza Oferta</span
        >
        <h2 class="text-3xl md:text-4xl font-extrabold text-slate-800 mt-3 mb-4">
          Przeglądaj wszystkie warsztaty
        </h2>
        <p class="text-slate-500 max-w-xl mx-auto text-base">
          Wybierz interesującą Cię grupę docelową lub wyszukaj konkretne zajęcia.
        </p>
      </div>

      <!-- Wyszukiwarka -->
      <div class="max-w-3xl mx-auto mb-10 relative">
        <div class="absolute inset-y-0 left-0 pl-5 flex items-center pointer-events-none">
          <svg
            class="h-5 w-5 text-brandPrimary"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg
          >
        </div>
        <label for="search-input" class="sr-only">Wyszukaj warsztaty</label>
        <input
          type="text"
          id="search-input"
          class="block w-full pl-12 pr-4 py-4 rounded-xl border-2 border-slate-100 bg-brandSlate text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-0 focus:border-brandPrimary focus:bg-white text-base transition shadow-sm"
          placeholder="Wpisz nazwę warsztatu, np. sensoryczne, kodowanie, pamięć..."
        />
      </div>

      <!-- System zakładek / filtrów -->
      <div class="flex flex-wrap justify-center gap-2.5 mb-8">
        <button
          class="filter-btn active bg-brandPrimary text-white px-6 py-2.5 rounded-xl font-bold text-sm transition shadow-md shadow-brandPrimary/20"
          data-filter="all"
        >
          Wszystkie zajęcia
        </button>
        <button
          class="filter-btn bg-brandSlate text-slate-600 hover:bg-brandAccentLight hover:text-brandPrimary px-6 py-2.5 rounded-xl font-bold text-sm transition"
          data-filter="dzieci"
        >
          👶 Dla dzieci
        </button>
        <button
          class="filter-btn bg-brandSlate text-slate-600 hover:bg-brandAccentLight hover:text-brandPrimary px-6 py-2.5 rounded-xl font-bold text-sm transition"
          data-filter="nauczyciele"
        >
          👩‍🏫 Dla nauczycieli
        </button>
        <button
          class="filter-btn bg-brandSlate text-slate-600 hover:bg-brandAccentLight hover:text-brandPrimary px-6 py-2.5 rounded-xl font-bold text-sm transition"
          data-filter="seniorzy"
        >
          🧓 Dla seniorów
        </button>
      </div>

      <!-- Tag filters -->
      <div class="flex flex-wrap justify-center gap-2 mb-12">
        <span class="text-sm font-semibold text-slate-500 self-center mr-2">Tagi:</span>
        <button
          class="tag-filter-btn active text-xs text-brandPrimary bg-brandAccentLight px-3 py-1.5 rounded-full transition font-medium"
          data-tag="all"
        >
          Wszystkie
        </button>
        <div id="tag-list" class="flex flex-wrap gap-2">
          {
            Array.from(courseTags)
              .sort()
              .slice(0, 8)
              .map((tag) => {
                return (
                  <button
                    class="tag-filter-btn text-xs text-slate-600 hover:text-brandPrimary hover:bg-brandAccentLight px-3 py-1.5 rounded-full transition font-medium"
                    data-tag={tag}
                  >
                    {tag}
                  </button>
                );
              })
          }
          {
            Array.from(courseTags)
              .sort()
              .slice(8)
              .map((tag) => {
                return (
                  <button
                    class="tag-filter-btn text-xs text-slate-600 hover:text-brandPrimary hover:bg-brandAccentLight px-3 py-1.5 rounded-full transition font-medium hidden"
                    data-tag={tag}
                  >
                    {tag}
                  </button>
                );
              })
          }
        </div>
        {
          courseTags.size > 8 && (
            <button
              id="expand-tags-btn"
              class="text-xs text-brandPrimary hover:text-brandPrimaryDark px-3 py-1.5 rounded-full transition font-medium"
            >
              +{courseTags.size - 8} więcej
            </button>
          )
        }
      </div>

      <!-- Komunikat braku wyników -->
      <div id="no-results" class="hidden text-center py-16">
        <span class="text-5xl block mb-4">🔍</span>
        <h3 class="text-xl font-bold text-slate-800">Nie znaleźliśmy takich warsztatów</h3>
        <p class="text-slate-500 mt-1">Spróbuj wpisać inną frazę lub zmień filtr kategorii.</p>
        <button
          id="reset-filters"
          class="mt-4 text-brandPrimary hover:text-brandPrimaryDark font-bold transition"
          >Wyczyść wyszukiwanie</button
        >
      </div>

      <!-- Siatka kart ze szkoleniami -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="course-grid">
        {allCourses.map((course) => <CourseCard course={course} />)}
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filterBtns = document.querySelectorAll('.filter-btn');
    const tagFilterBtns = document.querySelectorAll('.tag-filter-btn');
    const courseCards = document.querySelectorAll('.course-card');
    const searchInput = document.getElementById('search-input');
    const noResultsMsg = document.getElementById('no-results');
    const resetBtn = document.getElementById('reset-filters');
    const courseGrid = document.getElementById('course-grid');

    let currentCategory: string | null = 'all';
    let currentTag: string | null = 'all';
    let currentSearchTerm = '';

    function filterCourses() {
      let visibleCount = 0;

      courseCards.forEach((card) => {
        const titleEl = card.querySelector('h3');
        const descEl = card.querySelector('p');
        const title = titleEl?.innerText.toLowerCase() || '';
        const desc = descEl?.innerText.toLowerCase() || '';
        const category = card.getAttribute('data-category');
        const tags = card.getAttribute('data-tags')?.split(',') || [];

        const matchesSearch = title.includes(currentSearchTerm) || desc.includes(currentSearchTerm);
        const matchesCategory = currentCategory === 'all' || category === currentCategory;
        const matchesTag = currentTag === 'all' || tags.includes(currentTag);

        if (matchesSearch && matchesCategory && matchesTag) {
          card.classList.remove('hidden-card');
          visibleCount++;
        } else {
          card.classList.add('hidden-card');
        }
      });

      if (noResultsMsg && courseGrid) {
        if (visibleCount === 0) {
          noResultsMsg.classList.remove('hidden');
          courseGrid.classList.add('hidden');
        } else {
          noResultsMsg.classList.add('hidden');
          courseGrid.classList.remove('hidden');
        }
      }
    }

    if (searchInput) {
      searchInput.addEventListener('input', (e) => {
        const target = e.target as HTMLInputElement;
        currentSearchTerm = target.value.toLowerCase().trim();
        filterCourses();
      });
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach((b) => {
          b.classList.remove(
            'bg-brandPrimary',
            'text-white',
            'shadow-md',
            'shadow-brandPrimary/20',
            'active'
          );
          b.classList.add('bg-brandSlate', 'text-slate-600');
        });

        btn.classList.remove('bg-brandSlate', 'text-slate-600');
        btn.classList.add(
          'bg-brandPrimary',
          'text-white',
          'shadow-md',
          'shadow-brandPrimary/20',
          'active'
        );

        currentCategory = btn.getAttribute('data-filter');
        filterCourses();
      });
    });

    tagFilterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tagValue = btn.getAttribute('data-tag');
        currentTag = tagValue;

        tagFilterBtns.forEach((b) => {
          b.classList.remove('active', 'text-brandPrimary', 'bg-brandAccentLight');
          b.classList.add('text-slate-600');
        });

        btn.classList.remove('text-slate-600');
        btn.classList.add('active', 'text-brandPrimary', 'bg-brandAccentLight');

        filterCourses();
      });
    });

    // Handle expand/collapse tags
    const expandTagsBtn = document.getElementById('expand-tags-btn');
    if (expandTagsBtn) {
      expandTagsBtn.addEventListener('click', () => {
        const tagList = document.getElementById('tag-list');
        const hiddenTags = tagList?.querySelectorAll('.tag-filter-btn.hidden') || [];

        if (hiddenTags.length > 0) {
          hiddenTags.forEach((tag) => tag.classList.remove('hidden'));
          expandTagsBtn.textContent = 'Pokaż mniej';
        } else {
          const allTagButtons = tagList?.querySelectorAll('.tag-filter-btn') || [];
          allTagButtons.forEach((tag, index) => {
            if (index >= 8) {
              tag.classList.add('hidden');
            }
          });
          expandTagsBtn.textContent = `+${allTagButtons.length - 8} więcej`;
        }
      });
    }

    if (resetBtn && searchInput) {
      resetBtn.addEventListener('click', () => {
        (searchInput as HTMLInputElement).value = '';
        currentSearchTerm = '';
        currentTag = 'all';

        const defaultFilter = document.querySelector(
          '.filter-btn[data-filter="all"]'
        ) as HTMLElement;
        const defaultTagFilter = document.querySelector(
          '.tag-filter-btn[data-tag="all"]'
        ) as HTMLElement;

        if (defaultFilter) {
          defaultFilter.click();
        }
        if (defaultTagFilter) {
          defaultTagFilter.click();
        }
      });
    }
  });
</script>
