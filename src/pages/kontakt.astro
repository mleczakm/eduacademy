---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kontakt - Future Edu Academy">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-3xl">
      <h1 class="text-4xl font-bold text-slate-800 mb-4">Kontakt z Future Edu Academy</h1>
      <p class="text-lg text-slate-600 mb-8">
        Masz pytania? Chętnie pomożemy! Zarezerwuj 15-minutową rozmowę z naszym ekspertem.
      </p>

      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div>
          <h2 class="text-2xl font-bold text-slate-800 mb-4">Dane kontaktowe</h2>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="text-brandPrimary font-bold">Email:</span>
              <span class="text-slate-600">zapisy@futureedu.pl</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brandPrimary font-bold">Telefon:</span>
              <span class="text-slate-600">+48 123 456 789</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brandPrimary font-bold">Adres:</span>
              <span class="text-slate-600">ul. Edukacyjna 1, 00-000 Warszawa</span>
            </li>
          </ul>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-slate-800 mb-4">Godziny pracy</h2>
          <ul class="space-y-2 text-slate-600">
            <li>Poniedziałek - Piątek: 9:00 - 17:00</li>
            <li>Sobota: 10:00 - 14:00</li>
            <li>Niedziela: Zamknięte</li>
          </ul>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-lg p-8 mb-12">
        <h2 class="text-2xl font-bold text-slate-800 mb-6">Zarezerwuj 15-minutową rozmowę</h2>

        <div
          id="form-success"
          class="hidden bg-green-50 border border-green-200 rounded-xl p-4 mb-4"
        >
          <p class="text-green-800 font-medium">
            ✓ Dziękujemy! Twoja wiadomość została wysłana. Skontaktujemy się z Tobą wkrótce.
          </p>
        </div>

        <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
          <p class="text-red-800 font-medium">
            ✗ Wystąpił błąd. Spróbuj ponownie lub skontaktuj się telefonicznie.
          </p>
        </div>

        <form id="contact-form" class="space-y-4">
          <div>
            <label for="name" class="block text-sm font-bold text-slate-600 mb-1"
              >Imię i nazwisko</label
            >
            <input
              id="name"
              type="text"
              name="name"
              required
              class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-bold text-slate-600 mb-1"
              >Adres E-mail</label
            >
            <input
              id="email"
              type="email"
              name="email"
              required
              class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
            />
          </div>
          <div>
            <label for="message" class="block text-sm font-bold text-slate-600 mb-1"
              >Wiadomość / Pytania</label
            >
            <textarea
              id="message"
              name="message"
              rows="4"
              required
              class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
              placeholder="Opisz swoje potrzeby lub pytania..."></textarea>
          </div>

          <button
            type="submit"
            id="submit-btn"
            class="w-full bg-brandPrimary hover:bg-brandPrimaryDark text-white font-bold py-3.5 rounded-xl transition shadow-md"
          >
            Zarezerwuj rozmowę
          </button>
        </form>
      </div>

      <div class="mb-12">
        <h2 class="text-2xl font-bold text-slate-800 mb-4">Jak się zapisać?</h2>
        <p class="text-slate-600 mb-4">
          Najprostszym sposobem jest wypełnienie formularza zapisu na stronie wybranego szkolenia.
          Możesz też zarezerwować 15-minutową rozmowę telefoniczną lub wysłać nam e-mail.
        </p>
      </div>

      <div>
        <h2 class="text-2xl font-bold text-slate-800 mb-4">Social media</h2>
        <p class="text-slate-600 mb-4">
          Obserwuj nas na social media, aby być na bieżąco z nowościami:
        </p>
        <ul class="space-y-2 text-slate-600">
          <li>Facebook: @futureeduacademy</li>
          <li>Instagram: @futureeduacademy</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const successMessage = document.getElementById('form-success');
  const errorMessage = document.getElementById('form-error');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Disable button and show loading state
      submitBtn.disabled = true;
      submitBtn.textContent = 'Wysyłanie...';

      // Hide previous messages
      successMessage.classList.add('hidden');
      errorMessage.classList.add('hidden');

      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      try {
        const response = await fetch('https://formspree.io/f/meebjbol', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          // Show success message
          successMessage.classList.remove('hidden');
          form.reset();
        } else {
          // Show error message
          errorMessage.classList.remove('hidden');
        }
      } catch {
        // Show error message
        errorMessage.classList.remove('hidden');
      } finally {
        // Re-enable button
        submitBtn.disabled = false;
        submitBtn.textContent = 'Zarezerwuj rozmowę';
      }
    });
  }
</script>
