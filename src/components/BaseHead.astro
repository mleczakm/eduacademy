---
export interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  // Domyślne wartości, jeśli nie przekażesz ich w danej podstronie
  title = 'Warsztaty i szkolenia',
  description = 'Innowacyjne warsztaty i szkolenia dla dzieci, nauczycieli i seniorów. Rozwiń swoje kompetencje z ekspertami.',
  image = '/og-image-dark.png',
} = Astro.props;

// Automatyczne generowanie kanonicznego adresu URL
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://eduacademy.pl');
// Pełny adres obrazka OG
const ogImageUrl = new URL(image, Astro.site || 'https://eduacademy.pl');
---

<head title={title}>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - Future Edu Academy</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <link rel="icon" type="image/png" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="192x192" href="/android-chrome-192x192.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0055d4" />

  <link rel="preload" href="/logo.webp" as="image" type="image/webp" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={`${title} - Future Edu Academy`} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:site_name" content="Future Edu Academy" />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={`${title} - Future Edu Academy`} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={ogImageUrl} />
</head>
