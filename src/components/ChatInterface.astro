---
const chatId = 'chat-container';
---

<div
  id={chatId}
  data-chat-id={chatId}
  class="bg-white rounded-xl shadow-xl border border-slate-100 w-full overflow-hidden flex flex-col h-[500px]"
>
  <!-- Header -->
  <div
    class="bg-brandPrimary text-white px-5 py-4 flex justify-between items-center shadow-sm z-10"
  >
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 bg-white/20 rounded-xl flex items-center justify-center text-xl">
        🐨
      </div>
      <div>
        <h4 class="font-bold text-base">Asystent Akademii</h4>
        <span class="text-xs text-brandAccentLight flex items-center gap-1">
          <span class="status-indicator w-2 h-2 rounded-full inline-block bg-green-400"></span>
          <span class="status-text">Gotowy do rozmowy</span>
        </span>
      </div>
    </div>
  </div>

  <!-- Messages -->
  <div class="messages-container flex-1 overflow-y-auto p-5 space-y-5 bg-brandSlate text-sm"></div>

  <!-- Input -->
  <form class="p-4 border-t border-slate-100 bg-white flex gap-2">
    <div class="relative flex-grow">
      <input
        type="text"
        placeholder="Opisz swoje potrzeby..."
        class="w-full bg-brandSlate border border-transparent rounded-xl px-5 py-3 pr-10 text-sm focus:outline-none focus:ring-2 focus:ring-brandPrimary focus:bg-white transition"
      />
      <button
        type="button"
        class="clear-chat-btn absolute right-2 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 hover:bg-slate-200 p-1.5 rounded-lg transition"
        title="Wyczyść historię czatu"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
          ></path>
        </svg>
      </button>
    </div>
    <button
      type="submit"
      class="bg-brandPrimary hover:bg-brandPrimaryDark text-white p-3 rounded-xl transition flex-shrink-0"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
      </svg>
    </button>
  </form>

  <!-- Confirmation Modal -->
  <div
    id="clear-chat-modal"
    class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50"
  >
    <div class="bg-white rounded-2xl p-6 max-w-sm mx-4 shadow-2xl">
      <h3 class="text-lg font-semibold text-slate-800 mb-2">Wyczyść historię czatu?</h3>
      <p class="text-slate-600 text-sm mb-6">
        Ta akcja usunie całą historię rozmów i nie można jej cofnąć.
      </p>
      <div class="flex gap-3 justify-end">
        <button
          id="cancel-clear"
          class="px-4 py-2 text-slate-600 hover:bg-slate-100 rounded-xl transition text-sm font-medium"
        >
          Anuluj
        </button>
        <button
          id="confirm-clear"
          class="px-4 py-2 bg-red-500 hover:bg-red-600 text-white rounded-xl transition text-sm font-medium"
        >
          Wyczyść
        </button>
      </div>
    </div>
  </div>
</div>

<script src="./chatInterface.ts"></script>
