---
interface Props {
  course: {
    data: {
      title: string;
      category: string;
      priceFrom: string;
      tags: string[];
      image?: string;
    };
    id: string;
  };
}

const { course } = Astro.props;

const categoryEmoji =
  course.data.category === 'Dla dzieci'
    ? '👶'
    : course.data.category === 'Dla nauczycieli'
      ? '👩‍🏫'
      : '🧓';

const categoryClass =
  course.data.category === 'Dla dzieci'
    ? 'bg-brandAccentLight'
    : course.data.category === 'Dla nauczycieli'
      ? 'bg-brandSoftBlue'
      : 'bg-brandSlate';

const emoji =
  course.data.image ||
  (course.data.category === 'Dla dzieci'
    ? '🎨'
    : course.data.category === 'Dla nauczycieli'
      ? '📚'
      : '🧠');
---

<div
  class="course-card bg-white rounded-xl border border-slate-100 overflow-hidden flex flex-col shadow-sm"
  data-category={course.data.category === 'Dla dzieci'
    ? 'dzieci'
    : course.data.category === 'Dla nauczycieli'
      ? 'nauczyciele'
      : 'seniorzy'}
  data-tags={course.data.tags.join(',')}
>
  <div class={`h-44 ${categoryClass} flex items-center justify-center relative`}>
    <span
      class="absolute top-4 left-4 bg-white text-brandPrimary text-xs font-bold px-3 py-1.5 rounded-full shadow-sm"
      >{categoryEmoji} {course.data.category}</span
    >
    <span class="text-5xl">{emoji}</span>
  </div>
  <div class="p-6 flex-grow flex flex-col">
    <h3 class="text-xl font-bold text-slate-800 mb-2">{course.data.title}</h3>

    {
      course.data.tags && course.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {course.data.tags.slice(0, 3).map((tag) => {
            return (
              <button
                onclick={`document.querySelector('.tag-filter-btn[data-tag="${tag}"]')?.click(); window.scrollTo({top: document.getElementById('katalog').offsetTop - 100, behavior: 'smooth'});`}
                class="text-xs text-slate-500 hover:text-brandPrimary transition bg-slate-100 hover:bg-brandAccentLight px-2 py-1 rounded-full cursor-pointer"
              >
                {tag}
              </button>
            );
          })}
        </div>
      )
    }

    <p class="text-slate-500 text-sm mb-6 flex-grow">
      Kliknij "Szczegóły" aby zobaczyć pełny opis programu.
    </p>

    <div class="mt-auto border-t border-slate-100 pt-5 flex items-center justify-between">
      <span class="text-2xl font-bold text-slate-800">{course.data.priceFrom}</span>
      <div class="flex gap-2">
        <a
          href={`/szkolenia/${course.id}`}
          class="text-brandPrimary hover:text-brandPrimaryDark text-sm font-bold py-2 px-3 rounded-xl transition"
          >Szczegóły</a
        >
        <button
          data-course-title={course.data.title}
          onclick="openEnrollModal(this.getAttribute('data-course-title'))"
          class="bg-brandAccent hover:bg-brandPrimary text-white text-sm font-bold py-2 px-4 rounded-xl transition shadow-sm"
          >Zapisz się</button
        >
      </div>
    </div>
  </div>
</div>
