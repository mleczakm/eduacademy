---
import { ChatInterface } from './ChatInterface';
---

<section
  class="bg-gradient-to-b from-brandSoftBlue via-white to-white py-12 lg:py-20 border-b border-slate-100 overflow-hidden"
>
  <div
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"
  >
    <!-- Lewa strona: Tekst powitalny -->
    <div class="flex flex-col items-start text-left z-10">
      <span
        class="bg-brandAccentLight text-brandAccent font-bold tracking-wider uppercase text-xs px-3.5 py-1.5 rounded-full mb-4"
        >Odkryj radość z rozwoju</span
      >
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-slate-800 leading-tight mb-6">
        Miejsce twórczych <br class="hidden md:block" />warsztatów i <span class="text-brandPrimary"
          >edukacji</span
        >
      </h1>
      <p class="text-lg md:text-xl text-slate-600 max-w-lg mb-8 leading-relaxed">
        Stworzyliśmy przestrzeń rozwoju dla każdego wieku. Porozmawiaj z naszym asystentem, który
        pomoże dobrać idealne zajęcia dla Ciebie lub Twoich bliskich.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#katalog"
          class="px-8 py-3.5 bg-brandPrimary hover:bg-brandPrimaryDark text-white font-bold rounded-xl shadow-md hover:shadow-lg transition transform hover:-translate-y-0.5"
        >
          Przejdź do katalogu
        </a>
      </div>
    </div>

    <!-- Prawa strona: Custom Chat Interface -->
    <div class="w-full max-w-lg mx-auto lg:mx-0 lg:ml-auto relative">
      <!-- Dekoracyjne tło pod czatem (Pastelowe okręgi) -->
      <div class="absolute -inset-4 bg-brandPrimary/10 blur-3xl rounded-full z-0"></div>
      <div class="absolute -top-10 -right-10 w-24 h-24 bg-brandAccent/10 rounded-full blur-xl">
      </div>

      <div class="relative z-10 transform transition-all hover:scale-[1.01]">
        <ChatInterface client:load />
      </div>
    </div>
  </div>
</section>
