---
interface Props {
  courseTitle?: string;
}

const { courseTitle } = Astro.props;

const defaultMessage = courseTitle
  ? `Jestem zainteresowana/-y kursem "${courseTitle}", proszę o kontakt w sprawie rejestracji na zajęcia.`
  : '';
const modalTitle = courseTitle ? 'Zarezerwuj miejsce na zajęcia' : 'Zarezerwuj 15-minutową rozmowę';
---

<div
  id="enroll-modal"
  class="hidden fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-50 flex items-center justify-center"
>
  <div class="bg-white rounded-xl p-8 max-w-md w-full shadow-2xl">
    <h3 class="text-2xl font-bold text-slate-800 mb-4">{modalTitle}</h3>

    <div
      id="modal-form-success"
      class="hidden bg-green-50 border border-green-200 rounded-xl p-4 mb-4"
    >
      <p class="text-green-800 font-medium">
        ✓ Dziękujemy! Twoja wiadomość została wysłana. Skontaktujemy się z Tobą wkrótce.
      </p>
    </div>

    <div id="modal-form-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
      <p class="text-red-800 font-medium">
        ✗ Wystąpił błąd. Spróbuj ponownie lub skontaktuj się telefonicznie.
      </p>
    </div>

    <!-- Integracja Formspree -->
    <form id="modal-form" class="space-y-4">
      <!-- Ukryte pole z nazwą kursu (automatyczne przypisanie) -->
      {courseTitle && <input type="hidden" name="Szkolenie" value={courseTitle} />}

      <div>
        <label class="block text-sm font-bold text-slate-600 mb-1">Imię i nazwisko</label>
        <input
          type="text"
          name="name"
          required
          class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
        />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-600 mb-1">Adres E-mail</label>
        <input
          type="email"
          name="email"
          required
          class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
        />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-600 mb-1">Wiadomość / Pytania</label>
        <textarea
          name="message"
          rows="3"
          class="w-full bg-brandSlate border-2 border-slate-200 rounded-xl px-4 py-3 focus:outline-none focus:border-brandPrimary"
          placeholder={defaultMessage}>{defaultMessage}</textarea
        >
      </div>

      <button
        type="submit"
        id="modal-submit-btn"
        class="w-full bg-brandPrimary hover:bg-brandPrimaryDark text-white font-bold py-3.5 rounded-xl transition shadow-md"
      >
        Zarezerwuj rozmowę
      </button>
    </form>
    <button
      id="modal-cancel-btn"
      class="mt-4 text-slate-400 hover:text-slate-600 text-sm font-bold w-full text-center"
    >
      Anuluj
    </button>
  </div>
</div>

<script>
  const modalForm = document.getElementById('modal-form');
  const modalSubmitBtn = document.getElementById('modal-submit-btn');
  const modalSuccessMessage = document.getElementById('modal-form-success');
  const modalErrorMessage = document.getElementById('modal-form-error');
  const modalCancelBtn = document.getElementById('modal-cancel-btn');
  const enrollModal = document.getElementById('enroll-modal');

  if (modalForm) {
    modalForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Disable button and show loading state
      modalSubmitBtn.disabled = true;
      modalSubmitBtn.textContent = 'Wysyłanie...';

      // Hide previous messages
      modalSuccessMessage.classList.add('hidden');
      modalErrorMessage.classList.add('hidden');

      const formData = new FormData(modalForm);
      const data = Object.fromEntries(formData);

      try {
        const response = await fetch('https://formspree.io/f/meebjbol', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
          },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          // Show success message
          modalSuccessMessage.classList.remove('hidden');
          modalForm.reset();

          // Close modal after 2 seconds
          setTimeout(() => {
            if (enrollModal) {
              enrollModal.classList.add('hidden');
            }
          }, 2000);
        } else {
          // Show error message
          modalErrorMessage.classList.remove('hidden');
        }
      } catch {
        // Show error message
        modalErrorMessage.classList.remove('hidden');
      } finally {
        // Re-enable button
        modalSubmitBtn.disabled = false;
        modalSubmitBtn.textContent = 'Zarezerwuj miejsce na zaj';
      }
    });
  }

  if (modalCancelBtn && enrollModal) {
    modalCancelBtn.addEventListener('click', () => {
      enrollModal.classList.add('hidden');
    });
  }
</script>
